{
  "name": "open-sync",
  "version": "0.1.0",
  "description": "Desktop SSH discovery, connection management, and port forwarding",
  "type": "module",
  "main": "src/electron/main.js",
  "bin": {
    "open-sync": "src/cli/index.js"
  },
  "scripts": {
    "start": "electron .",
    "cli": "node src/cli/index.js",
    "web": "node src/web/server.js",
    "test": "node --test test/*.test.js",
    "dist": "electron-builder --mac",
    "dist:dir": "electron-builder --mac --dir"
  },
  "dependencies": {
    "bonjour-service": "^1.3.0",
    "commander": "^13.1.0",
    "express": "^5.1.0",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "electron": "^41.5.0",
    "electron-builder": "^26.0.12"
  },
  "overrides": {
    "@xmldom/xmldom": "0.8.13"
  },
  "build": {
    "appId": "com.opensync.app",
    "productName": "Open Sync",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": "dir",
      "icon": "build/icon.icns"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../open-dashboard",
        "to": "open-dashboard",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!**/.git/**",
          "!**/.claude/**",
          "!**/.DS_Store",
          "!**/.env",
          "!**/.env.*",
          "!**/*.pem",
          "!**/*.key",
          "!**/*.p12",
          "!**/*.pfx",
          "!**/id_rsa*",
          "!**/id_ed25519*",
          "!dist/**",
          "!coverage/**",
          "!tmp/**",
          "!output/**"
        ]
      },
      {
        "from": "../open-dashboard/node_modules",
        "to": "open-dashboard/node_modules",
        "filter": [
          "**/*",
          "!**/.git/**",
          "!**/.claude/**",
          "!**/.DS_Store",
          "!**/.env",
          "!**/.env.*",
          "!**/*.pem",
          "!**/*.key",
          "!**/*.p12",
          "!**/*.pfx",
          "!**/id_rsa*",
          "!**/id_ed25519*",
          "!**/tmp/**",
          "!**/output/**",
          "!**/coverage/**"
        ]
      }
    ],
    "asar": true
  }
}
